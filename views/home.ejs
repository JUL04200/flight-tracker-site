<%- include('partials/header', { title: 'Flight Tracker — Surveillance de vols intelligente', botUsername }) %>

<header class="hero">
  <div class="container">
    <h1>✈️ Flight Tracker</h1>
    <p class="lead">Recevez une alerte Telegram dès qu'un prix baisse ou qu'une disponibilité apparaît.</p>
    <div class="actions">
      <a href="#tarifs" class="btn btn-primary">🚀 Commencer</a>
      <a href="https://t.me/<%= botUsername %>" target="_blank" class="btn btn-secondary">💬 Ouvrir le bot Telegram</a>
    </div>
  </div>
</header>

<section>
  <div class="container">
    <div class="section-head">
      <div class="eyebrow">Comment ça fonctionne</div>
      <h2>Trois étapes, zéro effort</h2>
    </div>
    <div class="steps">
      <div class="step-card">
        <div class="step-num">1</div>
        <h3>Choisissez votre vol</h3>
        <p>Indiquez au bot le trajet ou la réservation que vous souhaitez surveiller.</p>
      </div>
      <div class="step-card">
        <div class="step-num">2</div>
        <h3>Flight Tracker surveille</h3>
        <p>Le bot vérifie automatiquement les prix et les disponibilités en continu.</p>
      </div>
      <div class="step-card">
        <div class="step-num">3</div>
        <h3>Vous êtes alerté</h3>
        <p>Recevez une notification Telegram dès qu'un changement est détecté.</p>
      </div>
    </div>
  </div>
</section>

<section class="soft">
  <div class="container">
    <div class="section-head">
      <div class="eyebrow">Fonctionnalités</div>
      <h2>Tout ce qu'il faut pour ne rien manquer</h2>
    </div>
    <div class="features-grid">
      <% features.forEach(f => { %>
        <div class="feature-card">
          <div class="feature-icon"><%= f.icon %></div>
          <h3><%= f.title %></h3>
          <p><%= f.text %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section id="tarifs">
  <div class="container">
    <div class="section-head">
      <div class="eyebrow">Tarifs</div>
      <h2>Choisissez votre formule</h2>
      <p>Sans engagement. Changez ou arrêtez à tout moment.</p>
    </div>
    <div class="pricing-grid">
      <% ['standard', 'premium'].forEach(key => { const plan = plans[key]; %>
        <div class="price-card <%= plan.highlight ? 'highlight' : '' %>">
          <% if (plan.highlight) { %><div class="price-badge">Le plus populaire</div><% } %>
          <h3><%= plan.label %></h3>
          <div class="price-amount"><%= plan.monthlyPrice.toFixed(2) %> € <span>/mois</span></div>
          <ul class="price-features">
            <% plan.features.forEach(f => { %><li><%= f %></li><% }) %>
          </ul>
          <a href="/checkout/<%= key %>" class="btn <%= plan.highlight ? 'btn-primary' : 'btn-secondary' %> btn-block">Choisir <%= plan.label %></a>
        </div>
      <% }) %>
    </div>

    <div class="trial-banner">
      <h3>🎁 Essai Premium gratuit de <%= trialDays %> jours</h3>
      <p>Testez toutes les fonctionnalités Premium sans carte bancaire, directement dans le bot.</p>
      <a href="https://t.me/<%= botUsername %>" target="_blank" class="btn btn-secondary">Démarrer l'essai gratuit</a>
    </div>
  </div>
</section>

<section class="soft">
  <div class="container">
    <div class="section-head">
      <div class="eyebrow">FAQ</div>
      <h2>Questions fréquentes</h2>
    </div>
    <div class="faq-list">
      <% faq.forEach(item => { %>
        <details class="faq-item">
          <summary><%= item.q %></summary>
          <p><%= item.a %></p>
        </details>
      <% }) %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
